# AIウェブマーケター 環境変数サンプル
#
# 使い方:
#   cp deploy/.env.example .env
#   編集して実値を入れる
#   chmod 600 .env
#
# .env はリポジトリのルートに置く(.gitignore で除外済み)

# --- アプリ基本 ---
MARKETER_ENV=development
MARKETER_BASE_URL=https://app.kiseeeen.co.jp/marketer
MARKETER_API_PORT=3009

# --- DB ---
# 形式: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
MARKETER_DB_DSN=postgresql+asyncpg://marketer:CHANGE_ME@127.0.0.1:5432/marketer
MARKETER_DB_PASSWORD=CHANGE_ME
MARKETER_DB_POOL_SIZE=5

# --- 暗号化 / JWT ---
# Fernet 鍵は: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MARKETER_FERNET_KEY=
# JWT 秘密鍵は: openssl rand -hex 32
MARKETER_JWT_SECRET=
MARKETER_JWT_TTL_MINUTES=60
MARKETER_JWT_REFRESH_TTL_DAYS=14

# --- システム共通 AI Provider キー(テナント別が無いときのフォールバック)---
# AI 処理用と引用モニタ用は別 Google アカウントで分離可能(無料枠分散のため)
MARKETER_GEMINI_API_KEY_AI_ENGINE=
MARKETER_GEMINI_API_KEY_CITATION_MONITOR=
MARKETER_OPENAI_API_KEY=
MARKETER_ANTHROPIC_API_KEY=
MARKETER_PERPLEXITY_API_KEY=
MARKETER_SERPAPI_KEY=

# --- メール送信 ---
# バックエンド切替("auto" は SMTP 優先 → Resend → 何もしない)
MARKETER_MAIL_BACKEND=auto
MARKETER_MAIL_FROM=your-gmail@gmail.com
MARKETER_MAIL_NOTIFY_TO=admin@kiseeeen.co.jp

# 案 B: Gmail SMTP リレー(無料、推奨)
# 1. https://myaccount.google.com/security で 2 段階認証を有効化
# 2. https://myaccount.google.com/apppasswords でアプリパスワード(16 文字)発行
MARKETER_SMTP_HOST=smtp.gmail.com
MARKETER_SMTP_PORT=587
MARKETER_SMTP_USER=your-gmail@gmail.com
MARKETER_SMTP_PASSWORD=

# 案 A: Resend(SMTP 設定なら不要)
MARKETER_RESEND_API_KEY=

# --- バックアップ ---
MARKETER_BACKUP_DIR=/var/backups/marketer
MARKETER_BACKUP_RETENTION_DAYS=7
